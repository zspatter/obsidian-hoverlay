{
	"name": "hoverlay",
	"version": "0.1.1",
	"description": "Obsidian plugin: link previews on hover that work on real websites.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"check:e2e": "tsc --noEmit -p e2e",
		"test:e2e": "npm run build && wdio run ./e2e/wdio.conf.mts",
		"shots": "npm run build && wdio run ./e2e/screenshots.conf.mts && node e2e/screenshots/make-gif.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "zspatter",
	"license": "MIT",
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"dompurify": "^3.2.3"
	},
	"devDependencies": {
		"@codemirror/state": "^6.4.0",
		"@codemirror/view": "^6.26.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.14.0",
		"@wdio/cli": "^9.29.1",
		"@wdio/globals": "^9.29.1",
		"@wdio/local-runner": "^9.29.1",
		"@wdio/mocha-framework": "^9.29.1",
		"esbuild": "^0.25.0",
		"gifenc": "^1.0.3",
		"jsdom": "^29.1.1",
		"mocha": "^10.8.2",
		"obsidian": "latest",
		"pngjs": "^7.0.0",
		"tslib": "^2.6.0",
		"tsx": "^4.23.0",
		"typescript": "^5.5.0",
		"vitest": "^3.0.0",
		"wdio-obsidian-reporter": "^3.1.1",
		"wdio-obsidian-service": "^3.1.1"
	}
}
